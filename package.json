{
  "name": "hammad-buckle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx lib/seed/index.ts",
    "postinstall": "prisma generate",
    "build:prod": "NODE_ENV=production next build --turbopack",
    "start:prod": "NODE_ENV=production next start -p 4000",
    "postbuild": "prisma generate",
    "deploy": "pnpm run build:prod && pnpm run start:prod",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop hammad-buckle",
    "pm2:restart": "pm2 restart hammad-buckle"
  },
